{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "QuantumScript",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#gates"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.qts",
          "match": "//.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.qts",
          "match": "\\b(if|import|from|export|const|new)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.qts",
          "match": "\\b(qubit|boolean)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.qts",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.qts",
          "begin": "\"",
          "end": "\""
        }
      ]
    },
    "gates": {
      "patterns": [
        {
          "name": "entity.name.function.qts",
          "match": "\\b(superpose|invert|measure)\\b"
        }
      ]
    }
  },
  "scopeName": "source.qts"
}
